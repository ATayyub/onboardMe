# Database — create your own PostgreSQL database (local or Supabase)
DATABASE_URL=postgresql://postgres@localhost:5432/onboardme
DIRECT_URL=postgresql://postgres@localhost:5432/onboardme

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Admin dashboard — your email for /admin access
ADMIN_EMAIL=your-email@example.com

# Sentry error tracking — create a project at sentry.io, then fill these in
# NEXT_PUBLIC_SENTRY_DSN is the only required var for basic error capture
NEXT_PUBLIC_SENTRY_DSN=
# Required only to upload source maps (set in Vercel/CI, not local dev)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
